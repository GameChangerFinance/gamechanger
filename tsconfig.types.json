{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "checkJs": false,
    "allowJs": false
  },
  "include": ["src"],
  "exclude": ["src/tests/**/*", "dist", "bin", "examples"]
}
